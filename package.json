{
  "name": "phasmo-overlay",
  "version": "1.0.0",
  "description": "Always-on-top Phasmophobia evidence/ghost cheat-sheet overlay",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "relay": "npm start --prefix server",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.5"
  },
  "build": {
    "appId": "com.phasmo.overlay",
    "productName": "PhasmoOverlay",
    "files": [
      "main.js",
      "config.js",
      "preload.js",
      "renderer/**/*",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "PhasmoOverlay-${version}.exe"
    }
  }
}
